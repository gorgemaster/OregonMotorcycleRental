---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  category?: string;
  categorySlug?: string;
  canonical?: string;
}

const { title, description, category, categorySlug, canonical } = Astro.props;
---

<Layout title={`${title} | Oregon Motorcycle Rental`} description={description} canonical={canonical}>

  <section class="post-hero">
    <div class="wrap">
      {category && (
        <a href={categorySlug ? `/category/${categorySlug}/` : '/oregon-motorcycle-rentals-news/'} class="post-cat">
          {category}
        </a>
      )}
      <h1 class="display post-title">{title}</h1>
    </div>
  </section>

  <div class="post-wrap wrap">
    <article class="post-body">
      <slot />
    </article>
    <aside class="post-sidebar">
      <div class="sidebar-card">
        <p class="sidebar-label">Ready to Ride?</p>
        <h3 class="display sidebar-title">Book a<br>Trip.</h3>
        <p class="sidebar-text">Call Doug to talk bikes, terrain, dates, and skill level. All gear included.</p>
        <a href="tel:5092810156" class="sidebar-phone">509-281-0156</a>
        <a href="/contact/" class="btn" style="margin-top:16px;display:block;text-align:center;">Contact Us</a>
      </div>
      <div class="sidebar-card sidebar-nav">
        <p class="sidebar-label">Quick Links</p>
        <nav class="sidebar-links">
          <a href="/motorcycle-rental-portland/">Bikes &amp; Pricing</a>
          <a href="/off-road-motorcycle-training/">Training</a>
          <a href="/tour-packages-motorcycle-rides-oregon/">Riding Locations</a>
          <a href="/reviews-testimonials-raves/">Reviews</a>
        </nav>
      </div>
    </aside>
  </div>

  <section class="post-cta">
    <div class="wrap">
      <h2 class="display post-cta-title">Let's ride.</h2>
      <a href="tel:5092810156" class="btn btn-big">509-281-0156</a>
    </div>
  </section>

</Layout>

<style>
  .post-hero {
    background: var(--ink);
    color: var(--cream);
    padding: 64px 0 56px;
    border-bottom: 3px solid var(--rust);
  }
  .post-cat {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rust);
    text-decoration: none;
    margin-bottom: 20px;
  }
  .post-cat::before {
    content: '';
    width: 28px;
    height: 2px;
    background: var(--rust);
  }
  .post-title {
    font-size: clamp(32px, 5vw, 72px);
    color: var(--cream);
    max-width: 22ch;
    line-height: 0.92;
  }

  .post-wrap {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 64px;
    padding-top: 64px;
    padding-bottom: 80px;
    align-items: start;
  }

  /* Article body */
  .post-body {
    max-width: 720px;
  }
  .post-body :global(h2) {
    font-family: 'Big Shoulders Display', sans-serif;
    font-weight: 900;
    font-size: clamp(28px, 3.5vw, 48px);
    text-transform: uppercase;
    color: var(--leather);
    margin: 48px 0 16px;
    line-height: 0.95;
  }
  .post-body :global(h3) {
    font-family: 'Big Shoulders Display', sans-serif;
    font-weight: 900;
    font-size: clamp(22px, 2.5vw, 36px);
    text-transform: uppercase;
    color: var(--leather);
    margin: 36px 0 12px;
    line-height: 1;
  }
  .post-body :global(p) {
    font-size: 18px;
    line-height: 1.72;
    color: var(--ink-2);
    margin-bottom: 24px;
  }
  .post-body :global(ul), .post-body :global(ol) {
    margin: 0 0 24px 24px;
  }
  .post-body :global(li) {
    font-size: 18px;
    line-height: 1.65;
    color: var(--ink-2);
    margin-bottom: 8px;
  }
  .post-body :global(img) {
    width: 100%;
    height: auto;
    margin: 32px 0;
  }
  .post-body :global(a) {
    color: var(--rust);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .post-body :global(blockquote) {
    border-left: 4px solid var(--rust);
    padding: 16px 24px;
    margin: 32px 0;
    background: var(--cream-deep);
    font-style: italic;
  }

  /* Sidebar */
  .sidebar-card {
    background: var(--cream-deep);
    padding: 32px;
    margin-bottom: 24px;
  }
  .sidebar-label {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 12px;
  }
  .sidebar-title {
    font-size: 48px;
    color: var(--leather);
    margin-bottom: 16px;
  }
  .sidebar-text {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
    margin-bottom: 16px;
  }
  .sidebar-phone {
    display: block;
    font-family: 'Big Shoulders Display', sans-serif;
    font-weight: 900;
    font-size: 28px;
    color: var(--rust);
    text-decoration: none;
  }
  .sidebar-phone:hover { color: var(--leather); }
  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .sidebar-links a {
    font-size: 15px;
    font-weight: 700;
    color: var(--leather);
    text-decoration: none;
    padding: 8px 0;
    border-bottom: 1px solid var(--line);
  }
  .sidebar-links a:hover { color: var(--rust); }

  /* CTA footer strip */
  .post-cta {
    background: var(--rust);
    color: var(--cream);
    padding: 60px 0;
    text-align: center;
  }
  .post-cta-title {
    font-size: clamp(48px, 6vw, 80px);
    color: var(--cream);
    margin-bottom: 24px;
  }

  @media (max-width: 900px) {
    .post-wrap {
      grid-template-columns: 1fr;
    }
    .post-sidebar {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .sidebar-card { margin-bottom: 0; }
  }
  @media (max-width: 600px) {
    .post-sidebar { grid-template-columns: 1fr; }
  }
</style>
