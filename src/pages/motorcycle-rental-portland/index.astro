---
import Layout from '../../layouts/Layout.astro';

const bikes = [
  {
    name: '2023 KTM 300 XC',
    tag: 'Most Popular',
    image: '/images/2025/02/Arizona-Dirt-Bike-Rentals-KTM-300-XC-2023.jpg',
    alt: '2023 KTM 300 XC dirt bike',
    upgrades: ['Rekluse "no-stall" auto-clutch', 'Custom-tuned suspension'],
    description: 'Maximum power at the least possible weight and smooth, linear power delivery – the 2023 KTM 300 XC is set to take the Open category back to school. Churning out massive power from an engine weighing only 52.6 lb, the KTM 300 XC sets the benchmark when it comes to power-to-weight ratios.',
  },
  {
    name: '2023 Husqvarna TE 300i',
    tag: 'Fuel Injected',
    image: '/images/2025/02/Arizona-Dirt-Bike-Rentals-Husqvarna-300-TE-2023.jpg',
    alt: '2023 Husqvarna TE 300i dirt bike',
    upgrades: ['Rekluse "no-stall" auto-clutch', 'Custom-tuned suspension'],
    description: "With electronic fuel injection, smooth power delivery and impressive torque and power, the TE 300i retains the traits it's become renowned for, now with class-leading chassis and ergonomics, it offers an even more controllable and thrilling ride.",
  },
  {
    name: '2022 Husqvarna 450 FX',
    tag: 'Advanced Only',
    image: '/images/2025/02/Arizona-Dirt-Bike-Rentals-Husqvarna-450-FX-2022.jpg',
    alt: '2022 Husqvarna 450 FX dirt bike',
    upgrades: ['Rekluse "no-stall" auto-clutch', 'Bib Moose no-flat tire inserts', 'Tuned custom suspension'],
    description: 'The pinnacle of Husqvarna offroad competition, the FX 450 uses advanced engineering techniques to position the engine closer to the center of gravity to vastly improve handling and maneuverability — class-leading ergonomics and traction control keep the rider in full control.',
  },
  {
    name: '2022 KTM 150 XC-W',
    tag: 'Light & Nimble',
    image: '/images/2025/02/Arizona-Dirt-Bike-Rentals-KTM-150-XC-W-2022.jpg',
    alt: '2022 KTM 150 XC-W dirt bike',
    upgrades: ['Rekluse "no-stall" auto-clutch', 'Custom-tuned suspension'],
    description: "The 2022 KTM 150 XC-W TPI features KTM's proven transfer port injection technology, supreme agility, and surprising 2-stroke power. Light and friendly enough to be ridden by beginners or raced hard by experienced riders.",
  },
  {
    name: '2022 Kawasaki KLX 140 RL',
    tag: 'Kids & Beginners',
    image: '/images/2025/02/Arizona-Dirt-Bike-Rentals-Kawasaki-KLX-140-RL-2022.jpg',
    alt: '2022 Kawasaki KLX 140 RL dirt bike',
    upgrades: ['Push-button electric starter', 'Larger 19″/16″ wheels'],
    description: "Perfect for bigger kids and smaller adults, the four-stroke air-cooled machine features a push-button electric starter and larger wheels (19″ front, 16″ rear) than the standard 140R. Its smooth, confidence-inspiring engine and five-speed transmission offer a user-friendly feel.",
  },
];
---

<Layout
  title="Motorcycle Dirt Bike Rental, Husqvarna and KTM | Oregon Motorcycle Rental"
  description="Motorcycle rental of Husqvarna and KTM dirt bikes for off-road enduro and single track riding in Oregon and Washington. View our newest motorcycle rentals."
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/rider-ktm.jpg" alt="" class="hero-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-body wrap">
      <p class="eyebrow">Motorcycles to Rent</p>
      <h1 class="display hero-title">Dirt Bike<br>Rental.</h1>
      <p class="hero-sub"><strong>Check out our range of Husqvarna and KTM dirt bikes. We have 150, 250, and 300 2-strokes, and 350 and 450 4-stroke motorcycles to choose from.</strong></p>
      <div class="hero-actions">
        <a href="tel:5092810156" class="btn btn-big">Call Doug</a>
      </div>
    </div>
  </section>

  <!-- Price strip -->
  <section class="price-strip">
    <div class="price-strip-inner wrap">
      <div class="price-main">
        <span class="price-num">$375</span>
        <span class="price-label">per rider / per day</span>
      </div>
      <ul class="price-includes">
        <li>All riding gear included</li>
        <li>Experienced trail guide</li>
        <li>Access to the best trails</li>
        <li>Bike prepped &amp; transported</li>
        <li>3–4 hour guided ride</li>
        <li>You just show up and ride</li>
      </ul>
    </div>
  </section>

  <!-- Fleet -->
  <section class="fleet" id="fleet">
    <div class="wrap fleet-header">
      <p class="section-label">Our Fleet</p>
      <h2 class="display fleet-title">Five bikes. All dialed in.</h2>
    </div>
    {bikes.map((bike, i) => (
      <div class={`bike-card ${i % 2 === 1 ? 'bike-card--flip' : ''}`}>
        <div class="bike-img-wrap">
          <img src={bike.image} alt={bike.alt} class="bike-img" loading="lazy" />
          <span class="bike-tag">{bike.tag}</span>
        </div>
        <div class="bike-body">
          <h3 class="display bike-name">{bike.name}</h3>
          <ul class="bike-upgrades">
            {bike.upgrades.map(u => <li>{u}</li>)}
          </ul>
          <p class="bike-desc">{bike.description}</p>
        </div>
      </div>
    ))}
  </section>

  <!-- Training strip -->
  <section class="training-strip">
    <div class="wrap training-inner">
      <div>
        <p class="section-label training-label">Add-On</p>
        <h2 class="display training-title">On-Trail Coaching.</h2>
        <p class="training-sub">Ride with a coach who gives real feedback in the moment — drills, technique, and trail-reading. Just $50/rider/day added to your rental.</p>
      </div>
      <div class="training-cta">
        <a href="/off-road-motorcycle-training/" class="btn-outline-light btn-big">About Training</a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="final-cta-bg"></div>
    <div class="wrap final-cta-body">
      <p class="section-label final-label">Ready to Ride</p>
      <h2 class="display final-title">Let's get you<br>on a bike.</h2>
      <a href="tel:5092810156" class="final-phone">509·281·0156</a>
      <p class="final-note">Call Doug to discuss bikes, skill level, terrain, and dates.</p>
      <a href="sms:5092810156" class="btn btn-big" target="_blank">Text Doug</a>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ───────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: var(--cream);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      color-mix(in srgb, var(--ink) 82%, transparent) 0%,
      color-mix(in srgb, var(--ink) 55%, transparent) 55%,
      color-mix(in srgb, var(--ink) 20%, transparent) 100%
    );
  }
  .hero-body {
    position: relative;
    z-index: 1;
    padding: 80px 24px 100px;
    max-width: 1240px;
    width: 100%;
    margin: 0 auto;
  }
  .hero-title {
    font-size: clamp(64px, 10vw, 120px);
    line-height: 0.95;
    margin: 16px 0 24px;
    color: var(--cream);
  }
  .hero-sub {
    font-size: 20px;
    line-height: 1.5;
    max-width: 520px;
    opacity: 0.88;
    margin-bottom: 40px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Price strip ────────────────────────────────────── */
  .price-strip {
    background: var(--rust);
    color: var(--cream);
    padding: 56px 0;
    position: relative;
    overflow: hidden;
  }
  .price-strip::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('/images/tire-tread.png') repeat center / 320px auto;
    opacity: 0.06;
    pointer-events: none;
  }
  .price-strip-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 48px;
    align-items: center;
  }
  .price-main {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    white-space: nowrap;
  }
  .price-num {
    font-family: 'Big Shoulders Display', sans-serif;
    font-weight: 900;
    font-size: clamp(72px, 10vw, 112px);
    line-height: 1;
  }
  .price-label {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
    opacity: 0.85;
    margin-top: 4px;
  }
  .price-includes {
    list-style: none;
    display: grid;
    grid-template-columns: auto auto;
    justify-content: start;
    gap: 10px 24px;
  }
  .price-includes li {
    font-size: 18px;
    padding-left: 20px;
    position: relative;
  }
  .price-includes li::before {
    content: '✓';
    position: absolute;
    left: 0;
    font-weight: 700;
    color: color-mix(in srgb, var(--cream) 70%, transparent);
  }
  @media (max-width: 640px) {
    .price-strip-inner { grid-template-columns: 1fr; gap: 32px; }
    .price-includes { grid-template-columns: 1fr; }
  }

  /* ── Fleet ──────────────────────────────────────────── */
  .fleet { padding: 100px 0 0; }
  .fleet-header { margin-bottom: 64px; }
  .fleet-title {
    font-size: clamp(36px, 5vw, 64px);
  }

  .bike-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 520px;
  }
  .bike-card--flip { direction: rtl; }
  .bike-card--flip > * { direction: ltr; }

  .bike-img-wrap {
    position: relative;
    overflow: hidden;
  }
  .bike-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bike-tag {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--rust);
    color: var(--cream);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 5px 12px;
  }

  .bike-body {
    padding: 56px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-left: 4px solid var(--rust);
    background: var(--cream-soft);
  }
  .bike-card--flip .bike-body {
    border-left: none;
    border-right: 4px solid var(--rust);
  }
  .bike-name {
    font-size: clamp(28px, 3.5vw, 48px);
    color: var(--leather);
    margin-bottom: 20px;
    line-height: 1.1;
  }
  .bike-upgrades {
    list-style: none;
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .bike-upgrades li {
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--rust);
    padding-left: 18px;
    position: relative;
  }
  .bike-upgrades li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--rust);
  }
  .bike-desc {
    font-size: 18px;
    line-height: 1.7;
    color: var(--ink-2);
  }

  @media (max-width: 900px) {
    .bike-card,
    .bike-card--flip {
      grid-template-columns: 1fr;
      direction: ltr;
      min-height: auto;
    }
    .bike-img-wrap { aspect-ratio: 16 / 9; }
    .bike-body {
      padding: 40px 24px;
      border-left: 4px solid var(--rust);
      border-right: none;
    }
    .bike-card--flip .bike-body {
      border-left: 4px solid var(--rust);
      border-right: none;
    }
  }

  /* ── Training strip ─────────────────────────────────── */
  .training-strip {
    background: var(--leather);
    color: var(--cream);
    padding: 80px 0;
    margin-top: 100px;
  }
  .training-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
    flex-wrap: wrap;
  }
  .training-label {
    color: color-mix(in srgb, var(--cream) 60%, transparent);
  }
  .training-title {
    font-size: clamp(40px, 5vw, 64px);
    color: var(--cream);
    margin: 12px 0 20px;
  }
  .training-sub {
    font-size: 18px;
    max-width: 480px;
    line-height: 1.6;
    opacity: 0.88;
  }
  .training-cta { flex-shrink: 0; }

  /* ── Final CTA ──────────────────────────────────────── */
  .final-cta {
    background: var(--ink);
    color: var(--cream);
    padding: 100px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .final-cta-bg {
    position: absolute;
    inset: 0;
    background: url('/images/tire-tread.png') center/cover no-repeat;
    opacity: 0.50;
    pointer-events: none;
  }
  .final-cta-body {
    position: relative;
    z-index: 1;
  }
  .final-label {
    color: color-mix(in srgb, var(--cream) 60%, transparent);
  }
  .final-title {
    font-size: clamp(48px, 8vw, 96px);
    color: var(--cream);
    margin: 16px 0 40px;
    line-height: 0.95;
  }
  .final-phone {
    display: block;
    font-family: 'Big Shoulders Display', sans-serif;
    font-weight: 900;
    font-size: clamp(48px, 9vw, 112px);
    color: var(--rust);
    text-decoration: none;
    line-height: 1;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .final-phone:hover { color: var(--cream); }
  .final-note {
    font-size: 18px;
    opacity: 0.7;
    margin-bottom: 40px;
  }
</style>
