---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Motorcycle Rental - Off Road Adventure | Oregon Motorcycle Rental"
  description="Doug currently guides full-time in Wickenburg, Arizona. Year-round desert riding, an hour from the Phoenix airport."
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/omr-locations.webp" alt="" class="hero-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-body wrap">
      <p class="eyebrow">Tour Locations</p>
      <h1 class="display hero-title">Now Riding<br>Wickenburg,<br>Arizona.</h1>
      <p class="hero-sub"><strong>Doug guides full-time in the Arizona desert. Year-round riding, an hour from the Phoenix airport. Sandy washes and miles of singletrack.</strong></p>
      <a href="tel:5092810156" class="btn btn-big">Talk to Doug</a>
    </div>
  </section>

  <!-- PNW note -->
  <section class="pnw-note">
    <div class="wrap">
      <h3>Pacific Northwest, paused</h3>
      <p>Doug previously guided at Hood River, Coastal Oregon, and Washington State. Those rides are paused while he's in Arizona. He may return north in the future.</p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="final-cta-bg"></div>
    <div class="wrap final-cta-body">
      <p class="section-label final-label">Plan Your Trip</p>
      <h2 class="display final-title">Bring your posse<br>or ride solo.</h2>
      <a href="tel:5092810156" class="final-phone">509 · 281 · 0156</a>
      <p class="final-note">Call Doug to book your Arizona ride.</p>
      <a href="https://arizonadirtbikerentals.com" class="btn btn-outline-light btn-big">Or Send a Message</a>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: var(--cream);
  }
  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center 35%; }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      color-mix(in srgb, var(--ink) 82%, transparent) 0%,
      color-mix(in srgb, var(--ink) 55%, transparent) 55%,
      color-mix(in srgb, var(--ink) 20%, transparent) 100%
    );
  }
  .hero-body {
    position: relative;
    z-index: 1;
    padding: 80px 24px 100px;
    max-width: 1240px;
    width: 100%;
    margin: 0 auto;
  }
  .hero-title {
    font-size: clamp(64px, 10vw, 120px);
    line-height: 0.95;
    margin: 16px 0 24px;
    color: var(--cream);
  }
  .hero-sub {
    font-size: 20px;
    line-height: 1.5;
    max-width: 48ch;
    opacity: 0.88;
    margin-bottom: 40px;
  }

  /* ── PNW note ─────────────────────────────────────── */
  .pnw-note {
    padding: 80px 0;
    background: var(--cream-deep);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .pnw-note h3 {
    font-family: 'Big Shoulders Display', sans-serif;
    font-weight: 900;
    font-size: clamp(28px, 3vw, 42px);
    text-transform: uppercase;
    color: var(--leather-soft);
    margin-bottom: 16px;
  }
  .pnw-note p {
    font-size: 18px;
    color: var(--leather-soft);
    max-width: 56ch;
    line-height: 1.6;
  }

  /* ── Final CTA ────────────────────────────────────── */
  .final-cta {
    background: var(--ink);
    color: var(--cream);
    padding: 100px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .final-cta-bg {
    position: absolute;
    inset: 0;
    background: url('/images/tire-tread.png') center/cover no-repeat;
    opacity: 0.50;
    pointer-events: none;
  }
  .final-cta-body { position: relative; z-index: 1; }
  .final-label { color: color-mix(in srgb, var(--cream) 60%, transparent); }
  .final-title {
    font-size: clamp(40px, 7vw, 88px);
    color: var(--cream);
    margin: 16px 0 40px;
    line-height: 0.95;
  }
  .final-phone {
    display: block;
    font-family: 'Big Shoulders Display', sans-serif;
    font-weight: 900;
    font-size: clamp(48px, 9vw, 112px);
    color: var(--rust);
    text-decoration: none;
    line-height: 1;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .final-phone:hover { color: var(--cream); }
  .final-note { font-size: 18px; opacity: 0.7; margin-bottom: 40px; }
</style>
